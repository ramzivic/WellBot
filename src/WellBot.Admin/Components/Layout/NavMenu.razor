@inject WellBot.Admin.Services.SimpleLocalizer Loc

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center" href="">
            <img src="/logo.png" alt="WellBot Logo" style="height: 30px; margin-right: 10px; border-radius: 5px;" />
            WellBot Admin
        </a>
    </div>
</div>

<div class="nav-scrollable">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> @Loc["Dashboard"]
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="health-tips">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> @Loc["HealthTips"]
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="notifications">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> @Loc["Notifications"]
            </NavLink>
        </div>
    </nav>
</div>
