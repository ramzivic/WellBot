@page "/notifications"
@using WellBot.Admin.Data
@using Microsoft.EntityFrameworkCore
@using WellBot.Admin.Entities
@using WellBot.Shared.Enums
@inject AppDbContext Db
@inject WellBot.Admin.Services.SimpleLocalizer Loc

<PageTitle>@Loc["Notifications"]</PageTitle>

<ErrorBoundary>
    <ChildContent>
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>@Loc["Notifications"]</h1>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">
                <strong>Error:</strong> @errorMessage
            </div>
        }

        @if (groups == null)
        {
            <p><em>@Loc["Loading"]</em></p>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (var group in groups)
                {
                    <div class="col">
                        <div class="card h-100 @(group.IsEnabled ? "" : "opacity-50")">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h5 class="mb-0">@group.Type</h5>
                            </div>
                            <div class="card-body">
                                <p><strong>@group.ConfigFr.Title</strong></p>
                                <p class="small text-muted">@group.ConfigFr.Message</p>
                                <hr />
                                <div class="d-flex justify-content-between align-items-center">
                                    <span>@Loc["Interval"]: <strong>@group.IntervalMinutes</strong></span>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch" 
                                               @bind="group.IsEnabled" @bind:after="@(() => Save(group))">
                                    </div>
                                </div>
                            </div>
                            <div class="card-footer bg-transparent border-top-0">
                                <button class="btn btn-sm btn-primary w-100" @onclick="() => Edit(group)">
                                    <i class="bi bi-gear"></i> @Loc["Configure"]
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        @if (showModal && editingGroup != null)
        {
            <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5)">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">@Loc["Configure"] : @editingGroup.Type</h5>
                            <button type="button" class="btn-close" @onclick="() => showModal = false"></button>
                        </div>
                        <div class="modal-body">
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">@Loc["Interval"]</label>
                                    <input type="number" class="form-control" @bind="editingGroup.IntervalMinutes" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">@Loc["Animation"]</label>
                                    <input type="text" class="form-control" @bind="editingGroup.AnimationName" />
                                </div>
                            </div>
                            
                            <ul class="nav nav-tabs mb-3">
                                <li class="nav-item">
                                    <button class="nav-link @(activeTab == "fr" ? "active" : "")" @onclick="@(() => activeTab = "fr")">Français</button>
                                </li>
                                <li class="nav-item">
                                    <button class="nav-link @(activeTab == "en" ? "active" : "")" @onclick="@(() => activeTab = "en")">English</button>
                                </li>
                                <li class="nav-item">
                                    <button class="nav-link @(activeTab == "ar" ? "active" : "")" @onclick="@(() => activeTab = "ar")">Arabe</button>
                                </li>
                            </ul>

                            @if (activeTab == "fr")
                            {
                                <div class="mb-3">
                                    <label class="form-label">@Loc["TitleFR"]</label>
                                    <input type="text" class="form-control" @bind="editingGroup.ConfigFr.Title" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">@Loc["MessageFR"]</label>
                                    <textarea class="form-control" rows="2" @bind="editingGroup.ConfigFr.Message"></textarea>
                                </div>
                            }
                            else if (activeTab == "en")
                            {
                                <div class="mb-3">
                                    <label class="form-label">@Loc["TitleEN"]</label>
                                    <input type="text" class="form-control" @bind="editingGroup.ConfigEn.Title" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">@Loc["MessageEN"]</label>
                                    <textarea class="form-control" rows="2" @bind="editingGroup.ConfigEn.Message"></textarea>
                                </div>
                            }
                            else if (activeTab == "ar")
                            {
                                <div class="mb-3" dir="rtl">
                                    <label class="form-label">@Loc["TitleAR"]</label>
                                    <input type="text" class="form-control" @bind="editingGroup.ConfigAr.Title" />
                                </div>
                                <div class="mb-3" dir="rtl">
                                    <label class="form-label">@Loc["MessageAR"]</label>
                                    <textarea class="form-control" rows="2" @bind="editingGroup.ConfigAr.Message"></textarea>
                                </div>
                            }
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="() => showModal = false">@Loc["Cancel"]</button>
                            <button type="button" class="btn btn-primary" @onclick="() => Save(editingGroup)">@Loc["Save"]</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </ChildContent>
    <ErrorContent Context="exception">
        <div class="alert alert-danger mt-4">
            <h4 class="alert-heading">Rendering Error</h4>
            <p>@exception.Message</p>
            <pre>@exception.StackTrace</pre>
        </div>
    </ErrorContent>
</ErrorBoundary>

@code {
    private List<NotificationGroup>? groups;
    private NotificationGroup? editingGroup;
    private bool showModal = false;
    private string? errorMessage;
    private string activeTab = "fr";

    class NotificationGroup
    {
        public NotificationType Type { get; set; }
        public int IntervalMinutes { get; set; }
        public string AnimationName { get; set; } = string.Empty;
        public bool IsEnabled { get; set; }

        public NotificationConfigEntity ConfigFr { get; set; } = new();
        public NotificationConfigEntity ConfigEn { get; set; } = new();
        public NotificationConfigEntity ConfigAr { get; set; } = new();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadConfigs();
    }

    private async Task LoadConfigs()
    {
        try
        {
            // Load all entities except "all"
            var allEntities = await Db.NotificationConfigs
                .Where(c => c.Language != "all")
                .ToListAsync();

            groups = allEntities.GroupBy(c => c.Type)
                .Select(g => {
                    var fr = g.FirstOrDefault(c => c.Language == "fr") ?? new NotificationConfigEntity { Type = g.Key, Language = "fr" };
                    var en = g.FirstOrDefault(c => c.Language == "en") ?? new NotificationConfigEntity { Type = g.Key, Language = "en" };
                    var ar = g.FirstOrDefault(c => c.Language == "ar") ?? new NotificationConfigEntity { Type = g.Key, Language = "ar" };

                    return new NotificationGroup
                    {
                        Type = g.Key,
                        // Take shared properties from the French config (or any existing one)
                        IntervalMinutes = fr.IntervalMinutes,
                        AnimationName = fr.AnimationName,
                        IsEnabled = fr.IsEnabled,
                        ConfigFr = fr,
                        ConfigEn = en,
                        ConfigAr = ar
                    };
                })
                .OrderBy(g => g.Type)
                .ToList();
        }
        catch (Exception ex)
        {
            errorMessage = "LoadConfigs error: " + ex.ToString();
        }
    }

    private void Edit(NotificationGroup group)
    {
        editingGroup = group;
        activeTab = "fr";
        showModal = true;
    }

    private async Task Save(NotificationGroup group)
    {
        try
        {
            errorMessage = null;
            var now = DateTime.UtcNow;

            // Apply shared fields to all entities
            var entities = new[] { group.ConfigFr, group.ConfigEn, group.ConfigAr };
            foreach (var entity in entities)
            {
                entity.IntervalMinutes = group.IntervalMinutes;
                entity.AnimationName = group.AnimationName;
                entity.IsEnabled = group.IsEnabled;
                entity.UpdatedAt = now;

                if (entity.Id == 0)
                {
                    Db.NotificationConfigs.Add(entity);
                }
                else
                {
                    Db.Entry(entity).State = EntityState.Modified;
                }
            }

            await Db.SaveChangesAsync();
            showModal = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = "Save error: " + ex.ToString();
        }
    }
}
