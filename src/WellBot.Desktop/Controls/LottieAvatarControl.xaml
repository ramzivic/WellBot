<UserControl x:Class="WellBot.Desktop.Controls.LottieAvatarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="150" d:DesignWidth="150">
    <Grid>
        <!-- Avatar head image with transforms for tilt animation -->
        <Image Name="AvatarImage" Stretch="Uniform" RenderTransformOrigin="0.5,0.7">
            <Image.RenderTransform>
                <TransformGroup>
                    <RotateTransform x:Name="AvatarRotation" Angle="0" />
                    <TranslateTransform x:Name="AvatarTranslation" Y="0" />
                </TransformGroup>
            </Image.RenderTransform>
        </Image>

        <!-- Beautiful water glass overlay (hidden by default) -->
        <Canvas Name="WaterGlassCanvas" 
                Width="32" Height="42"
                HorizontalAlignment="Right" 
                VerticalAlignment="Bottom"
                Margin="0,0,2,2"
                Opacity="0"
                RenderTransformOrigin="0.5,0.5">
            <Canvas.RenderTransform>
                <TransformGroup>
                    <TranslateTransform x:Name="GlassTranslation" X="0" Y="0" />
                    <RotateTransform x:Name="GlassRotation" Angle="0" />
                </TransformGroup>
            </Canvas.RenderTransform>

            <!-- Glass body (transparent with white border) -->
            <Path Stroke="#AABCCEE8" StrokeThickness="1.8" Fill="#22B0D0F0">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="4,4" IsClosed="True">
                            <LineSegment Point="7,38" />
                            <ArcSegment Point="25,38" Size="3,3" SweepDirection="Clockwise" />
                            <LineSegment Point="28,4" />
                            <ArcSegment Point="4,4" Size="20,3" SweepDirection="Clockwise" />
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>

            <!-- Water fill (blue gradient) -->
            <Path>
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="6,16" IsClosed="True">
                            <LineSegment Point="7.5,36" />
                            <ArcSegment Point="24.5,36" Size="2.5,2.5" SweepDirection="Clockwise" />
                            <LineSegment Point="26,16" />
                            <!-- Wavy top surface -->
                            <BezierSegment Point1="23,14" Point2="20,18" Point3="16,16" />
                            <BezierSegment Point1="12,14" Point2="9,17" Point3="6,16" />
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
                <Path.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#8844AAEE" Offset="0" />
                        <GradientStop Color="#AA2288DD" Offset="0.5" />
                        <GradientStop Color="#CC1166CC" Offset="1" />
                    </LinearGradientBrush>
                </Path.Fill>
            </Path>

            <!-- Glass shine/reflection (left side) -->
            <Path Fill="#30FFFFFF">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="6,6" IsClosed="True">
                            <LineSegment Point="8,34" />
                            <LineSegment Point="12,34" />
                            <LineSegment Point="10,6" />
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>

            <!-- Glass shine highlight (small) -->
            <Ellipse Canvas.Left="8" Canvas.Top="8" Width="4" Height="6" 
                     Fill="#40FFFFFF" />

            <!-- Bubbles inside water -->
            <Ellipse Canvas.Left="14" Canvas.Top="24" Width="3" Height="3"
                     Fill="#40FFFFFF" Stroke="#20FFFFFF" StrokeThickness="0.5" />
            <Ellipse Canvas.Left="19" Canvas.Top="28" Width="2" Height="2"
                     Fill="#35FFFFFF" />
            <Ellipse Canvas.Left="11" Canvas.Top="30" Width="1.5" Height="1.5"
                     Fill="#30FFFFFF" />

            <!-- Glass rim highlight -->
            <Ellipse Canvas.Left="5" Canvas.Top="2" Width="22" Height="5"
                     Stroke="#40BCCEE8" StrokeThickness="0.8" Fill="Transparent" />
        </Canvas>
    </Grid>
</UserControl>
