<Window x:Class="WellBot.Desktop.Views.AvatarSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:localControls="clr-namespace:WellBot.Desktop.Controls"
        xmlns:enums="clr-namespace:WellBot.Shared.Enums;assembly=WellBot.Shared"
        mc:Ignorable="d"
        Title="Bienvenue sur WellBot" 
        Height="650" Width="850"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <localControls:StepToVisibilityConverter x:Key="StepToVis" />
        <localControls:NullToVisibilityConverter x:Key="NullToVis" />
    </Window.Resources>

    <Border CornerRadius="30" Background="White" BorderThickness="1" BorderBrush="#EEEEEE">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.15" />
        </Border.Effect>
        
        <Grid>
            <!-- Step 1: Welcome Intro -->
            <Grid Margin="40" Visibility="{Binding CurrentStep, Converter={StaticResource StepToVis}, ConverterParameter=1}">
                <StackPanel VerticalAlignment="Center">
                    <Image x:Name="ImgBot" Height="180" Margin="0,0,0,20" />
                    <Image x:Name="ImgLogo" Height="40" HorizontalAlignment="Center" />
                    
                    <TextBlock FontSize="36" FontWeight="Bold" Foreground="#2D3436" HorizontalAlignment="Center" Margin="0,40,0,0">
                        <Run x:Name="TxtWelcome1" Text="Bienvenue sur "/><Run Text="WellBot" Foreground="{StaticResource OoredooRedBrush}" />
                    </TextBlock>
                    <TextBlock x:Name="TxtSubWelcome" Text="Votre compagnon bien-être au travail." 
                               FontSize="18" Foreground="#636E72" HorizontalAlignment="Center" Margin="0,10,0,40" />
                    
                    <Button x:Name="BtnStartConfig" Content="Commencer la configuration" 
                            Width="280" Height="55" 
                            Background="{StaticResource OoredooRedBrush}" Foreground="White" 
                            FontSize="18" FontWeight="Bold"
                            Command="{Binding NextStepCommand}"
                            HorizontalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Step 2: Customization -->
            <Grid Margin="40" Visibility="{Binding CurrentStep, Converter={StaticResource StepToVis}, ConverterParameter=2}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,30">
                    <TextBlock FontSize="32" FontWeight="Bold" Foreground="#2D3436" HorizontalAlignment="Center">
                        <Run x:Name="TxtHello" Text="Bonjour, " /><Run Text="{Binding UserName}" Foreground="{StaticResource OoredooRedBrush}" />
                    </TextBlock>
                    <TextBlock x:Name="TxtLetsCustomize" Text="Personnalisons votre assistant." 
                               FontSize="16" Foreground="#636E72" HorizontalAlignment="Center" Margin="0,5,0,0" />
                </StackPanel>

                <!-- Name Field -->
                <StackPanel Grid.Row="1" Width="350" Margin="0,0,0,30">
                    <TextBlock x:Name="TxtNameQuestion" Text="Comment souhaitez-vous être appelé ?" FontSize="14" FontWeight="SemiBold" Foreground="#2D3436" Margin="0,0,0,8" />
                    <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" 
                             FontSize="16" Padding="15,12" Background="#F8F9FA" BorderThickness="1" BorderBrush="#E9ECEF">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10" />
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </StackPanel>

                <!-- Avatar Selection -->
                <Grid Grid.Row="2">
                    <StackPanel>
                        <TextBlock x:Name="TxtChooseAvatar" Text="Choisissez votre avatar :" FontSize="16" FontWeight="SemiBold" Foreground="#2D3436" Margin="0,0,0,20" HorizontalAlignment="Center" />
                        
                        <UniformGrid Columns="2" HorizontalAlignment="Center">
                            <!-- Bot 1: Bearded Man -->
                            <Button Command="{Binding SelectAvatarCommand}" CommandParameter="1" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bdr" Margin="10" Padding="15" CornerRadius="20" BorderThickness="2" BorderBrush="Transparent">
                                            <localControls:LottieAvatarControl AvatarType="Bot1" AnimationName="idle" Height="180" Width="180" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding SelectedAvatar}" Value="{x:Static enums:AvatarType.Bot1}">
                                                <Setter TargetName="Bdr" Property="BorderBrush" Value="{StaticResource OoredooRedBrush}" />
                                                <Setter TargetName="Bdr" Property="Background" Value="#FFF0F0" />
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Bot 2: Veiled Woman -->
                            <Button Command="{Binding SelectAvatarCommand}" CommandParameter="2" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bdr" Margin="10" Padding="15" CornerRadius="20" BorderThickness="2" BorderBrush="Transparent">
                                            <localControls:LottieAvatarControl AvatarType="Bot2" AnimationName="idle" Height="180" Width="180" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding SelectedAvatar}" Value="{x:Static enums:AvatarType.Bot2}">
                                                <Setter TargetName="Bdr" Property="BorderBrush" Value="{StaticResource OoredooRedBrush}" />
                                                <Setter TargetName="Bdr" Property="Background" Value="#FFF0F0" />
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </UniformGrid>
                    </StackPanel>
                </Grid>

                <!-- Footer -->
                <Button x:Name="BtnLetsGo" Grid.Row="3" Content="C'est parti !" 
                        Width="250" Height="50" 
                        Background="{StaticResource OoredooRedBrush}" Foreground="White" 
                        FontSize="18" FontWeight="Bold"
                        Command="{Binding ConfirmCommand}"
                        Margin="0,30,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Close Button (Z-Index on top) -->
            <Button Command="{Binding CloseCommand}" 
                    HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Margin="20" Width="40" Height="40" 
                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bdr" CornerRadius="20" Background="Transparent">
                            <TextBlock Text="✕" FontSize="20" Foreground="#636E72" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bdr" Property="Background" Value="#F8F9FA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</Window>
