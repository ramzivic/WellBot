<Window x:Class="WellBot.Desktop.Views.NotificationPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:localControls="clr-namespace:WellBot.Desktop.Controls"
        Title="WellBot Notification" 
        MinHeight="180" Width="400"
        SizeToContent="Height"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent" 
        Topmost="True" 
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">
    
    <Border x:Name="MainBorder" CornerRadius="20" Margin="10" Background="White">
        <Border.RenderTransform>
            <TranslateTransform x:Name="MainTransform" x:FieldModifier="public" Y="200" />
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3" Color="Black" />
        </Border.Effect>

        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Using our safe custom control that handles gender/pose switching -->
            <localControls:LottieAvatarControl Grid.Column="0" 
                                               AvatarType="{Binding SelectedAvatar}" 
                                               AnimationName="{Binding AnimationName}" 
                                               CustomPath="{Binding CustomPath}"
                                               Margin="5" />

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="#2D3436" />
                <TextBlock Text="{Binding Message}" FontSize="14" Foreground="#636E72" TextWrapping="Wrap" Margin="0,5,0,10" />
                
                <Button Content="{Binding AcknowledgeText}" 
                        Width="120" Height="35" 
                        HorizontalAlignment="Left"
                        Background="{StaticResource OoredooRedBrush}" Foreground="White" 
                        Command="{Binding AcknowledgeCommand}" />
            </StackPanel>
            
            <Button Content="✕" 
                    HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Background="Transparent" BorderThickness="0" 
                    Foreground="#636E72" FontSize="16"
                    Command="{Binding DismissCommand}" />
        </Grid>
    </Border>
</Window>
