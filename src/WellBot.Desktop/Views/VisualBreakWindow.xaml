<Window x:Class="WellBot.Desktop.Views.VisualBreakWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:localControls="clr-namespace:WellBot.Desktop.Controls"
        Title="WellBot Notification" 
        Width="220" Height="260"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent" 
        Topmost="True" 
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Row 0: "J'ai compris" button + close button at the TOP, always clickable -->
        <Grid Grid.Row="0" Margin="5,0,5,0" Panel.ZIndex="20">
            <Button x:Name="AcknowledgeBtn"
                    Content="{Binding AcknowledgeText}"
                    Padding="8,4"
                    FontSize="10"
                    Cursor="Hand"
                    Background="#E84118" Foreground="White"
                    BorderThickness="0"
                    Opacity="0"
                    HorizontalAlignment="Stretch"
                    Click="OnAcknowledgeClick">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

            <!-- Small close button on top right -->
            <Button x:Name="CloseBtn"
                    Content="✕"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,-5,-5,0"
                    Width="20" Height="20"
                    FontSize="10"
                    Background="White" Foreground="#636E72"
                    BorderBrush="#DCDDE1"
                    Cursor="Hand"
                    Opacity="0"
                    Click="OnCloseClick">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <!-- Row 1: Speech bubble with title and message text -->
        <Grid Grid.Row="1" Margin="5,4,5,5" Panel.ZIndex="1">
            <Border x:Name="SpeechBubble" 
                    CornerRadius="12" 
                    Background="White" 
                    Padding="12,8"
                    Opacity="0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2" Color="Black" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{Binding Title}" 
                               FontSize="13" FontWeight="SemiBold" 
                               Foreground="#2D3436" 
                               TextWrapping="Wrap" 
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding Message}" 
                               FontSize="11" 
                               Foreground="#636E72" 
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" 
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Row 2: Avatar container, in front of speech bubble text -->
        <Grid Grid.Row="2" x:Name="AvatarContainer" Panel.ZIndex="10" IsHitTestVisible="False">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="AvatarSlideTransform" Y="180" />
            </Grid.RenderTransform>

            <!-- Shared rotation/scale container: avatar + eyelids move together -->
            <Grid RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="AvatarScale" ScaleX="1" ScaleY="1" />
                        <RotateTransform x:Name="HeadRotation" Angle="0" />
                        <TranslateTransform x:Name="HeadTranslation" X="0" />
                    </TransformGroup>
                </Grid.RenderTransform>

                <!-- Avatar head -->
                <localControls:LottieAvatarControl x:Name="AvatarControl" 
                                                   Width="120" Height="120"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />

                <!-- Left eyelid - positioned at eye level -->
                <Canvas HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="-28,3,0,0" Width="20" Height="10" ClipToBounds="True">
                    <Border x:Name="LeftEyelid"
                            Canvas.Top="-12"
                            Width="20" Height="12"
                            CornerRadius="10,10,2,2"
                            Background="#F0D5C0"
                            Opacity="0">
                        <Border.Effect>
                            <BlurEffect Radius="1" />
                        </Border.Effect>
                    </Border>
                </Canvas>

                <!-- Right eyelid - positioned at eye level -->
                <Canvas HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="22,3,0,0" Width="20" Height="10" ClipToBounds="True">
                    <Border x:Name="RightEyelid"
                            Canvas.Top="-12"
                            Width="20" Height="12"
                            CornerRadius="10,10,2,2"
                            Background="#F0D5C0"
                            Opacity="0">
                        <Border.Effect>
                            <BlurEffect Radius="1" />
                        </Border.Effect>
                    </Border>
                </Canvas>
            </Grid>
        </Grid>
    </Grid>
</Window>
